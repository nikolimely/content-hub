generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  domain      String
  githubRepo  String
  repoBranch  String    @default("main")
  contentPath String    @default("content/blog")
  contentTypes String?  // JSON: [{"label":"Posts","path":"content/posts"}]
  assetsPath  String    @default("public/images/blog")
  imageWidth  Int       @default(1200)
  imageHeight Int       @default(800)
  description String?
  logo        String?
  faviconUrl  String?
  model       String    @default("claude-sonnet-4-6")
  brandVoice  String?
  tone        String?
  targetAudience String?
  externalLinksPath String?
  authorsPath   String?
  deployHook    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles    Article[]
  authors     Author[]
}

model Author {
  id       String   @id @default(cuid())
  siteId   String
  site     Site     @relation(fields: [siteId], references: [id])
  name     String
  slug     String
  bio      String?
  avatar   String?
  articles Article[]

  @@unique([siteId, slug])
}

model Article {
  id          String   @id @default(cuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  authorId    String?
  author      Author?  @relation(fields: [authorId], references: [id])

  title       String
  slug        String
  keyword     String
  category    String?
  contentType String   @default("post")
  metaDescription String?
  status      String   @default("planned")
  content     String?
  heroImage   String?
  images      String?
  scheduledAt DateTime?
  publishedAt DateTime?
  errorLog    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteId, slug])
}
